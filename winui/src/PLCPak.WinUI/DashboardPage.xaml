<UserControl
    x:Class="PLCPak.WinUI.DashboardPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:infra="using:PLCPak.WinUI.Infrastructure">

    <UserControl.Resources>
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
        <infra:BoolToVisibilityConverter x:Key="BoolToVis" />
        <infra:InverseBoolConverter x:Key="InverseBool" />
        <infra:ResourceKeyToBrushConverter x:Key="BrushKeyConv" />
        <Style x:Key="PlcMetricCardButton" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource PlcAccentSubtleBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource PlcNavHighlightBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <StackPanel
            Spacing="4"
            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding RefreshingHint}" />
        </StackPanel>
        <TextBlock Style="{StaticResource PlcPageTitle}" Text="{Binding DashboardTitle}" />
        <TextBlock
            Style="{StaticResource PlcHintText}"
            Text="{Binding DashboardSimpleHint}"
            Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />
        <TextBlock
            Style="{StaticResource PlcHintText}"
            Text="{Binding DashboardProHint}"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
        <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WorkspacePath}" />

        <ItemsControl ItemsSource="{Binding MetricCards}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="5" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Margin" Value="0,0,8,8" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Width" Value="140" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Command="{Binding DataContext.OpenMetricFilterCommand, ElementName=Root}"
                        CommandParameter="{Binding FilterKey}"
                        IsEnabled="{Binding DataContext.IsRefreshing, ElementName=Root, Converter={StaticResource InverseBool}}"
                        Style="{StaticResource PlcMetricCardButton}"
                        ToolTipService.ToolTip="{Binding Tip}">
                        <Border Style="{StaticResource PlcMetricCard}">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Label}" />
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{Binding AccentBrushKey, Converter={StaticResource BrushKeyConv}}"
                                    Text="…"
                                    Visibility="{Binding DataContext.IsRefreshing, ElementName=Root, Converter={StaticResource BoolToVis}}" />
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="{Binding AccentBrushKey, Converter={StaticResource BrushKeyConv}}"
                                    Text="{Binding Value}"
                                    Visibility="{Binding DataContext.IsRefreshing, ElementName=Root, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            </StackPanel>
                        </Border>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock
            Style="{StaticResource PlcHintText}"
            Text="{Binding MetricsLoadingHint}"
            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />

        <Border Style="{StaticResource PlcHeroCard}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding SmartNextTitle}" />
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding SmartNextLoadingHint}"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                <TextBlock FontSize="15" Text="{Binding NextActionSummaryText}" TextWrapping="Wrap" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding NextActionLabel}" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding NextActionReason}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Style="{StaticResource PlcPrimaryButton}"
                        Command="{Binding GoToNextActionCommand}"
                        Content="{Binding GoLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}" />
                    <Button
                        Style="{StaticResource PlcPrimaryButton}"
                        Command="{Binding ExecuteNextActionCommand}"
                        Content="{Binding RunLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}" />
                    <Button
                        Command="{Binding RegisterScheduleTaskCommand}"
                        Content="{Binding RegisterScheduleLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                    <Button
                        Command="{Binding CopyScheduleCommandCommand}"
                        Content="{Binding CopyScheduleLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                    <Button
                        Command="{Binding ExportScheduleBatchCommand}"
                        Content="{Binding ExportScheduleLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource PlcContentCard}">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding StatsTitle}" />
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding StatsLoadingHint}"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                <TextBlock
                    Text="{Binding StatsSummaryText}"
                    TextWrapping="Wrap"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Command="{Binding FilterFailedCommand}"
                        Content="{Binding ViewFailedLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}" />
                    <Button
                        Command="{Binding FilterPendingCommand}"
                        Content="{Binding ViewPendingLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}" />
                    <Button
                        Command="{Binding FilterArchivedCommand}"
                        Content="{Binding ViewArchivedLabel}"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid ColumnSpacing="12" Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding WorkspaceHealthTitle}" />
                    <TextBlock Text="{Binding WorkspaceHealthText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding JobHealthTitle}" />
                    <TextBlock Text="{Binding JobHealthText}" TextWrapping="Wrap" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding HealthLoadingHint}"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding HealthIssuesEmptyHint}"
                        TextWrapping="Wrap"
                        Visibility="{Binding IsHealthIssuesEmpty, Converter={StaticResource BoolToVis}}" />
                    <ListView
                        MaxHeight="220"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        IsItemClickEnabled="True"
                        ItemClick="HealthIssues_ItemClick"
                        ItemsSource="{Binding HealthIssues}"
                        SelectionMode="None"
                        Visibility="{Binding IsHealthIssuesEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding Severity}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel
            Orientation="Horizontal"
            Spacing="8"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <Button Command="{Binding RefreshCommand}" Content="{Binding RefreshLabel}" />
            <Button Command="{Binding BatchGenerateQueueCopyCommand}" Content="{Binding BatchGenCopyLabel}" />
            <Button Command="{Binding ExportPublishQueueCsvCommand}" Content="{Binding ExportQueueCsvLabel}" />
            <Button Command="{Binding BatchRunAutomatableChainCommand}" Content="{Binding BatchAutoRunLabel}" />
            <Button Command="{Binding BatchMarkQueuePublishedCommand}" Content="{Binding BatchMarkPublishedLabel}" />
            <Button Command="{Binding ExportAllJobsBackupCommand}" Content="{Binding BackupJobsLabel}" />
            <Button Command="{Binding ExportFullBackupCommand}" Content="{Binding BackupFullLabel}" />
            <Button Command="{Binding ImportJobsBackupCommand}" Content="{Binding RestoreJobsLabel}" />
            <Button Command="{Binding ImportFullBackupCommand}" Content="{Binding RestoreFullLabel}" />
            <Button Command="{Binding ExportHealthReportCommand}" Content="{Binding ExportHealthLabel}" />
            <Button Command="{Binding ExportDailyReportCommand}" Content="{Binding ExportDailyLabel}" />
            <Button Command="{Binding OpenWorkspaceCommand}" Content="{Binding OpenWorkspaceLabel}" />
        </StackPanel>
        <StackPanel
            Orientation="Horizontal"
            Spacing="8"
            Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
            <Button Command="{Binding RefreshCommand}" Content="{Binding RefreshLabel}" />
            <Button Command="{Binding OpenWorkspaceCommand}" Content="{Binding OpenWorkspaceLabel}" />
        </StackPanel>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding TgPendingTitle}" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding QueuesLoadingHint}"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding TgPendingSummary}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding PreviewTgPendingCommand}" Content="{Binding PreviewTgLabel}" />
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding BatchSendTgPendingCommand}"
                            Content="{Binding BatchTgLabel}" />
                        <Button
                            Command="{Binding ExportTgPendingCsvCommand}"
                            Content="{Binding ExportTgCsvLabel}"
                            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                        <Button Command="{Binding RefreshCommand}" Content="{Binding RefreshLabel}" />
                    </StackPanel>
                    <ListView
                        x:Name="TgPendingList"
                        MaxHeight="240"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        IsItemClickEnabled="True"
                        ItemClick="TgPending_ItemClick"
                        ItemsSource="{Binding TgPendingEntries}"
                        SelectionMode="None"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                            Text="{Binding Reason}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource PlcSecondaryTextBrush}">
                                            <Run Text="{Binding DataContext.CopyLabelText, ElementName=Root}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding HasCopy}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="SendTgPending_Click"
                                        Content="{Binding DataContext.SendLabel, ElementName=TgPendingList}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel
                        Spacing="8"
                        Visibility="{Binding TgPendingEmptyHint, Converter={StaticResource StringToVis}}">
                        <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding TgPendingEmptyHint}" />
                        <Button Command="{Binding RefreshCommand}" Content="{Binding RefreshLabel}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding PublishQueueTitle}" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding QueuesLoadingHint}"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding PublishQueueSummaryText}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding RefreshCommand}" Content="{Binding RefreshQueueLabel}" />
                    </StackPanel>
                    <ListView
                        MaxHeight="320"
                        IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                        IsItemClickEnabled="True"
                        ItemClick="PublishQueue_ItemClick"
                        ItemsSource="{Binding PublishQueue}"
                        SelectionMode="None"
                        Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding PublishSummary}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}">
                                        <Run Text="{Binding DataContext.ChannelsFilledLabel, ElementName=Root}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding ReadyChannelCount}" />
                                        <Run Text="/3" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel
                        Spacing="8"
                        Visibility="{Binding PublishQueueEmptyHint, Converter={StaticResource StringToVis}}">
                        <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding PublishQueueEmptyHint}" />
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding GoToJobsFromEmptyQueueCommand}"
                            Content="{Binding GoToJobsLabel}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Style="{StaticResource PlcContentCard}">
            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding RecentJobsTitle}" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding RecentJobsCountText}" />
                </Grid>
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding RecentJobsLoadingHint}"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
                <TextBlock
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding RecentJobsEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding IsRecentJobsEmpty, Converter={StaticResource BoolToVis}}" />
                <ListView
                    IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBool}}"
                    IsItemClickEnabled="True"
                    ItemClick="RecentJobs_ItemClick"
                    ItemsSource="{Binding RecentJobs}"
                    SelectionMode="None"
                    Visibility="{Binding IsRecentJobsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding StatusLabel}" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding LastLogLine}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>