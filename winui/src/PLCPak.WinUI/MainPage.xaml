<UserControl
    x:Class="PLCPak.WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:infra="using:PLCPak.WinUI.Infrastructure">

    <UserControl.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis" />
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <StackPanel
            Spacing="4"
            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding QuickRefreshingHint}" />
        </StackPanel>
        <TextBlock Style="{StaticResource PlcPageTitle}" Text="{Binding QuickPageTitle}" />
        <TextBlock
            Style="{StaticResource PlcHintText}"
            Text="{Binding QuickSimpleHint}"
            Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />

        <Border Style="{StaticResource PlcHeroCard}" Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="{Binding QuickHeroTitle}" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding QuickHeroFlow}" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding TaskStatus}" />
            </StackPanel>
        </Border>

        <Grid ColumnSpacing="12" Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding QuickRecentProjectsLabel}" VerticalAlignment="Center" />
            <ComboBox
                x:Name="RecentCombo"
                Grid.Column="1"
                ItemsSource="{Binding RecentProjects}"
                SelectedItem="{Binding SelectedRecentProject, Mode=TwoWay}"
                SelectionChanged="RecentCombo_SelectionChanged" />
            <Button Grid.Column="2" Click="SettingsButton_Click" Content="{Binding QuickSettingsLabel}" />
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="{Binding QuickSourceListHeader}" />
            <TextBlock
                Grid.Column="1"
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding QuickSourceCountLoadingHint}"
                Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                Grid.Column="1"
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding QuickSourceCountText}"
                Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
        </Grid>

        <TextBlock
            FontSize="12"
            Foreground="{ThemeResource PlcAccentBrush}"
            Text="{Binding QuickDropFeedbackText}"
            Visibility="{Binding QuickDropFeedbackText, Converter={StaticResource StringToVis}}" />
        <Grid MinHeight="120" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                x:Name="SourceDropPanel"
                AllowDrop="True"
                Background="{ThemeResource PlcLayerFillBrush}"
                BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                DragOver="SourceDropPanel_DragOver"
                DragLeave="SourceDropPanel_DragLeave"
                Drop="SourceDropPanel_Drop">
                <Grid MinHeight="96">
                    <ListView
                        x:Name="SourceListView"
                        CanDragItems="True"
                        CanReorderItems="True"
                        ItemsSource="{Binding SourceItems}"
                        SelectionMode="Extended"
                        Visibility="{Binding IsSourceListEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding QuickSourceEmptyHint}"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Visibility="{Binding IsSourceListEmpty, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>
            <StackPanel Grid.Column="1" Spacing="8">
                <Button Command="{Binding AddFolderCommand}" Content="{Binding QuickAddFolderLabel}" />
                <Button Command="{Binding AddFileCommand}" Content="{Binding QuickAddFileLabel}" />
                <Button Click="RemoveSelected_Click" Content="{Binding QuickRemoveSelectedLabel}" />
            </StackPanel>
        </Grid>

        <TextBlock FontSize="14" Text="{Binding TotalSizeText}" />

        <CheckBox
            Content="{Binding QuickSelfPurchaseLabel}"
            IsChecked="{Binding SelfPurchase, Mode=TwoWay}"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />

        <Border Style="{StaticResource PlcContentCard}" Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding QuickSevenZTitle}" />
                <CheckBox
                    Content="{Binding QuickEnableCompressionLabel}"
                    IsChecked="{Binding Enable7z, Mode=TwoWay}"
                    IsEnabled="{Binding Enable7zOption}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{Binding QuickOutputNameLabel}" />
                    <TextBox
                        Grid.Column="1"
                        PlaceholderText="{Binding QuickSevenZOutputPlaceholder}"
                        Text="{Binding SevenZOutputName, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text=".7z" />
                </Grid>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{Binding QuickVolumeSizeMbLabel}" />
                    <TextBox
                        Grid.Column="1"
                        PlaceholderText="1900"
                        Text="{Binding VolumeSizeText, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding QuickVolumeSizeHint}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource PlcContentCard}" Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding QuickTarZstTitle}" />
                <CheckBox
                    Content="{Binding QuickEnableCompressionLabel}"
                    IsChecked="{Binding EnableTarZst, Mode=TwoWay}"
                    IsEnabled="{Binding EnableTarOption}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{Binding QuickOutputNameLabel}" />
                    <TextBox Grid.Column="1" Text="{Binding TarZstOutputName, Mode=TwoWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text=".tar.zst" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource PlcContentCard}" Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding QuickAdSamplesTitle}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcAccentBrush}"
                    Text="{Binding QuickAdDropFeedbackText}"
                    Visibility="{Binding QuickAdDropFeedbackText, Converter={StaticResource StringToVis}}" />
                <Border
                    x:Name="AdDropPanel"
                    MinHeight="42"
                    AllowDrop="True"
                    Background="{ThemeResource PlcLayerFillBrush}"
                    BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    DragOver="AdDropPanel_DragOver"
                    DragLeave="AdDropPanel_DragLeave"
                    Drop="AdDropPanel_Drop">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding QuickAdDropHint}" />
                </Border>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Command="{Binding OpenAdSamplesFolderCommand}" Content="{Binding QuickBrowseSamplesLabel}" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding SyncAdManifestCommand}"
                        Content="{Binding QuickSyncManifestLabel}" />
                    <CheckBox
                        Grid.Column="2"
                        Content="{Binding QuickPruneLargeSamplesLabel}"
                        IsChecked="{Binding AutoPruneLargeSamples, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Text="{Binding AdSampleCountText}" />
                </Grid>
            </StackPanel>
        </Border>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar
                IsIndeterminate="{Binding IsProgressIndeterminate}"
                Maximum="100"
                Value="{Binding ProgressValue}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Text="{Binding ProgressText}" />
        </Grid>

        <TextBox
            AcceptsReturn="True"
            FontFamily="Consolas"
            Height="120"
            IsReadOnly="True"
            Text="{Binding LogText}"
            TextWrapping="Wrap" />

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Command="{Binding PreviewCleanupCommand}"
                Content="{Binding QuickPreviewCleanupLabel}"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            <Button
                Grid.Column="1"
                Command="{Binding ExportLogCommand}"
                Content="{Binding QuickExportLogLabel}"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            <Button
                Grid.Column="2"
                Style="{StaticResource PlcPrimaryButton}"
                Command="{Binding ExecuteCommand}"
                Content="{Binding QuickExecuteLabel}"
                IsEnabled="{Binding CanExecute}" />
        </Grid>
    </StackPanel>
</UserControl>