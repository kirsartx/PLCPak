<UserControl
    x:Class="PLCPak.WinUI.JobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:PLCPak.Core"
    xmlns:infra="using:PLCPak.WinUI.Infrastructure"
    xmlns:viewModels="using:PLCPak.WinUI.ViewModels"
    x:Name="JobsPageRoot">

    <UserControl.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis" />
        <infra:InverseBoolConverter x:Key="InverseBool" />
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
        <infra:IntToVisibilityConverter x:Key="IntToVis" />
        <infra:JobStatusBackgroundConverter x:Key="JobStatusBg" />
        <infra:WizardStepCurrentBorderConverter x:Key="WizardCurrentBorderConverter" />
        <infra:WizardStepBorderThicknessConverter x:Key="WizardBorderThicknessConverter" />
    </UserControl.Resources>

    <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="8">
            <TextBlock x:Name="WorkbenchTitleBlock" Style="{StaticResource PlcPageTitle}" Text="{Binding JobsWorkbenchTitle}" />
            <TextBlock
                Style="{StaticResource PlcHintText}"
                Text="{Binding JobsSimpleHint}"
                Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding JobsWizardShortcuts}"
                TextWrapping="Wrap"
                Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding JobsProShortcutsLine}"
                ToolTipService.ToolTip="{Binding JobsProShortcutsTooltip}"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding StatsSummaryText}"
                TextWrapping="Wrap" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding WorkspacePath}"
                TextWrapping="Wrap" />

            <TextBox
                Header="{Binding JobsSidebarNewGameHeader}"
                PlaceholderText="{Binding JobsSidebarNewJobPlaceholder}"
                Text="{Binding NewTitle, Mode=TwoWay}" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Header="{Binding JobsSidebarThreadUrlHeader}" Text="{Binding ThreadUrl, Mode=TwoWay}" />
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Command="{Binding PasteThreadUrlCommand}"
                    Content="{Binding JobsSidebarPasteLink}" />
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Bottom"
                    Command="{Binding FetchThreadInfoCommand}"
                    Content="{Binding JobsSidebarFetchThreadInfo}" />
            </Grid>
            <ComboBox
                Header="{Binding JobsSidebarSourceForum}"
                ItemsSource="{Binding ForumSiteOptions}"
                SelectedItem="{Binding SelectedSite, Mode=TwoWay}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding CreateJobCommand}" Content="{Binding JobsSidebarNewJob}" />
                <Button Command="{Binding CreateJobFromThreadCommand}" Content="{Binding JobsSidebarCreateFromThread}" />
            </StackPanel>
            <TextBlock
                Foreground="#C45500"
                Text="{Binding DuplicateWarningText}"
                TextWrapping="Wrap"
                Visibility="{Binding HasDuplicateWarning, Converter={StaticResource BoolToVis}}" />

            <TextBox
                Header="{Binding JobsSidebarSearchJobs}"
                PlaceholderText="{Binding JobsSidebarSearchPlaceholder}"
                Text="{Binding JobSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox
                x:Name="JobFilterComboBox"
                Header="{Binding JobsSidebarJobFilter}"
                ItemsSource="{Binding JobFilterOptions}"
                SelectedItem="{Binding SelectedJobFilter, Mode=OneWay}"
                SelectionChanged="JobFilterComboBox_SelectionChanged" />
            <ComboBox
                x:Name="JobSortComboBox"
                Header="{Binding JobsSidebarSort}"
                ItemsSource="{Binding JobSortOptions}"
                SelectedItem="{Binding SelectedJobSort, Mode=OneWay}"
                SelectionChanged="JobSortComboBox_SelectionChanged"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            <ComboBox
                x:Name="JobTagFilterComboBox"
                Header="{Binding JobsSidebarTagFilter}"
                ItemsSource="{Binding TagFilterOptions}"
                SelectedItem="{Binding SelectedTagFilter, Mode=OneWay}"
                SelectionChanged="JobTagFilterComboBox_SelectionChanged"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />

            <StackPanel
                Spacing="4"
                Visibility="{Binding IsRefreshingJobs, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding JobsRefreshingHint}" />
            </StackPanel>
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding JobsFilterSummaryText}"
                TextWrapping="Wrap"
                Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVis}}" />
            <Button
                HorizontalAlignment="Left"
                Command="{Binding ClearFiltersCommand}"
                Content="{Binding JobsClearFiltersLabel}"
                Visibility="{Binding IsFilterActive, Converter={StaticResource BoolToVis}}" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding JobsListCountText}" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcAccentBrush}"
                Text="{Binding JobsMultiSelectHint}"
                Visibility="{Binding HasJobSelection, Converter={StaticResource BoolToVis}}" />

            <Grid>
                <ListView
                    x:Name="JobsListView"
                    Height="280"
                    DoubleTapped="JobsListView_DoubleTapped"
                    ItemsSource="{Binding Jobs}"
                    SelectionChanged="JobsListView_SelectionChanged"
                    SelectionMode="Multiple"
                    Visibility="{Binding IsJobsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="4"
                                Background="{Binding Status, Converter={StaticResource JobStatusBg}}"
                                CornerRadius="4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="#C45500"
                                            Text="★"
                                            Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding StatusLabel}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding PublishStatusLabel}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{Binding IsJobsEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding JobsEmptyList}"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Visibility="{Binding IsFilterEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                    <TextBlock
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding JobsFilterEmptyHint}"
                        TextAlignment="Center"
                        TextWrapping="Wrap"
                        Visibility="{Binding IsFilterEmpty, Converter={StaticResource BoolToVis}}" />
                    <Button
                        HorizontalAlignment="Center"
                        Command="{Binding ClearFiltersCommand}"
                        Content="{Binding JobsClearFiltersLabel}"
                        Visibility="{Binding IsFilterEmpty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>

            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <Button
                    Command="{Binding BatchAppendTagsToSelectedCommand}"
                    Content="{Binding JobsSidebarBatchAppendTags}"
                    Visibility="{Binding HasMultiJobSelection, Converter={StaticResource BoolToVis}}" />
                <Button
                    Command="{Binding BatchArchiveSelectedCommand}"
                    Content="{Binding JobsSidebarBatchArchiveSelected}"
                    Visibility="{Binding HasMultiJobSelection, Converter={StaticResource BoolToVis}}" />
                <Button
                    Command="{Binding BatchUnarchiveSelectedCommand}"
                    Content="{Binding JobsSidebarBatchUnarchiveSelected}"
                    Visibility="{Binding HasMultiJobSelection, Converter={StaticResource BoolToVis}}" />
                <Button
                    Command="{Binding BatchDeleteSelectedCommand}"
                    Content="{Binding JobsSidebarBatchDeleteSelected}"
                    Visibility="{Binding HasMultiJobSelection, Converter={StaticResource BoolToVis}}" />
                <Button Command="{Binding BatchArchiveFilteredCommand}" Content="{Binding JobsSidebarBatchArchiveFiltered}" />
                <Button Command="{Binding BatchPinFilteredCommand}" Content="{Binding JobsSidebarBatchPinFiltered}" />
                <Button Command="{Binding BatchUnpinFilteredCommand}" Content="{Binding JobsSidebarBatchUnpinFiltered}" />
                <Button Command="{Binding ArchiveJobCommand}" Content="{Binding JobsSidebarArchiveJob}" />
                <Button
                    Command="{Binding UnarchiveJobCommand}"
                    Content="{Binding JobsSidebarUnarchiveJob}"
                    Visibility="{Binding IsSelectedJobArchived, Converter={StaticResource BoolToVis}}" />
                <Button Command="{Binding DeleteJobCommand}" Content="{Binding JobsSidebarDeleteJob}" />
            </StackPanel>
            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <Button Command="{Binding ExportJobJsonCommand}" Content="{Binding JobsSidebarExportJobJson}" />
                <Button Command="{Binding ExportFilteredJobsCsvCommand}" Content="{Binding JobsSidebarExportFilteredCsv}" />
                <Button Command="{Binding ExportFilteredJobsJsonCommand}" Content="{Binding JobsSidebarExportFilteredJson}" />
                <Button Command="{Binding ExportSelectedJobsCsvCommand}" Content="{Binding JobsSidebarExportSelectedCsv}" />
                <Button Command="{Binding ExportPinnedJobsCsvCommand}" Content="{Binding JobsSidebarExportPinnedCsv}" />
                <Button Command="{Binding ImportJobJsonCommand}" Content="{Binding JobsSidebarImportJobJson}" />
                <Button Command="{Binding ImportPanLinksCsvCommand}" Content="{Binding JobsSidebarImportPanLinksCsv}" />
            </StackPanel>
            <Button Command="{Binding RefreshJobsCommand}" Content="{Binding JobsSidebarRefreshList}" />
            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <Button Command="{Binding ExportPublishHistoryCommand}" Content="{Binding JobsSidebarExportPublishHistory}" />
                <Button Command="{Binding BatchGeneratePublishCopyCommand}" Content="{Binding JobsSidebarBatchGenerateCopy}" />
                <Button Command="{Binding BatchRunPipelineCommand}" Content="{Binding JobsSidebarBatchPipeline}" />
                <Button Command="{Binding BatchRunAutomatableChainCommand}" Content="{Binding JobsSidebarBatchAutoChain}" />
                <Button Command="{Binding OpenWorkspaceCommand}" Content="{Binding JobsSidebarOpenWorkspace}" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer x:Name="JobDetailScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <Grid MinHeight="360">
            <Border
                Padding="24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="{ThemeResource PlcLayerFillBrush}"
                BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding HasWizardJob, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center" Spacing="12" MaxWidth="360">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{Binding JobsEmptyDetailTitle}"
                        TextAlignment="Center" />
                    <TextBlock
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding JobsEmptyDetailHint}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding PasteThreadUrlCommand}" Content="{Binding JobsSidebarPasteLink}" />
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding CreateJobFromThreadCommand}"
                            Content="{Binding JobsSidebarCreateFromThread}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="8" Visibility="{Binding HasWizardJob, Converter={StaticResource BoolToVis}}">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="{Binding SelectedJobDisplayTitle}" />

            <Border Style="{StaticResource PlcHeroCard}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding JobsNextActionTitle}" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding JobsNextActionLoadingHint}"
                        Visibility="{Binding IsRefreshingJobs, Converter={StaticResource BoolToVis}}" />
                    <TextBlock
                        FontSize="14"
                        Text="{Binding SelectedJobNextActionDisplayText}"
                        TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding ExecuteSelectedNextActionCommand}"
                            Content="{Binding JobsDetailExecuteSuggestedAction}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}" />
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding RunFullPipelineCommand}"
                            Content="{Binding JobsDetailRunFullPipeline}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}"
                            Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />
                        <Button
                            Command="{Binding RunAutomatableChainCommand}"
                            Content="{Binding JobsDetailAutoRunUntilManual}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}"
                            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Expander
                Header="{Binding JobsCollapseMoreSettings}"
                IsExpanded="{Binding IsJobDetailMoreSettingsExpanded, Mode=TwoWay}"
                Visibility="{Binding ShowJobDetailExtrasCollapsed, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <ProgressBar
                        Maximum="100"
                        Value="{Binding PipelineProgressPercent, Mode=OneWay}"
                        Visibility="{Binding PipelineProgressPercent, Converter={StaticResource IntToVis}}" />

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Header="{Binding JobsDetailJobNotes}"
                            AcceptsReturn="True"
                            Height="72"
                            PlaceholderText="{Binding JobsDetailJobNotesPlaceholder}"
                            Text="{Binding JobNotes, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Command="{Binding SaveNotesCommand}"
                            Content="{Binding JobsDetailSaveNotes}" />
                    </Grid>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Header="{Binding JobsDetailArchivePassword}"
                            PlaceholderText="{Binding JobsDetailArchivePasswordPlaceholder}"
                            Text="{Binding ArchivePassword, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Command="{Binding SavePasswordCommand}"
                            Content="{Binding JobsDetailSavePassword}" />
                    </Grid>

                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource PlcAccentBrush}"
                        Text="{Binding JobsInboxDropFeedbackText}"
                        Visibility="{Binding JobsInboxDropFeedbackText, Converter={StaticResource StringToVis}}" />
                    <Border
                        x:Name="InboxDropPanelCollapsed"
                        MinHeight="40"
                        AllowDrop="True"
                        Background="{ThemeResource PlcLayerFillBrush}"
                        BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        DragOver="InboxDropPanel_DragOver"
                        DragLeave="InboxDropPanel_DragLeave"
                        Drop="InboxDropPanel_Drop">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                            Text="{Binding JobsDetailInboxDropHint}" />
                    </Border>

                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource PlcAccentBrush}"
                        Text="{Binding PipelineProgressText}"
                        TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding OpenExtractCommand}" Content="{Binding JobsDetailOpenExtract}" />
                        <Button Command="{Binding OpenOutputCommand}" Content="{Binding JobsDetailOpenOutput}" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <StackPanel
                Spacing="8"
                Visibility="{Binding ShowJobDetailExtrasCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
            <ProgressBar
                Maximum="100"
                Value="{Binding PipelineProgressPercent, Mode=OneWay}"
                Visibility="{Binding PipelineProgressPercent, Converter={StaticResource IntToVis}}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Header="{Binding JobsDetailJobNotes}"
                    AcceptsReturn="True"
                    Height="72"
                    PlaceholderText="{Binding JobsDetailJobNotesPlaceholder}"
                    Text="{Binding JobNotes, Mode=TwoWay}"
                    TextWrapping="Wrap" />
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Command="{Binding SaveNotesCommand}"
                    Content="{Binding JobsDetailSaveNotes}" />
            </Grid>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Header="{Binding JobsDetailArchivePassword}"
                    PlaceholderText="{Binding JobsDetailArchivePasswordPlaceholder}"
                    Text="{Binding ArchivePassword, Mode=TwoWay}" />
                <Button
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Command="{Binding SavePasswordCommand}"
                    Content="{Binding JobsDetailSavePassword}" />
            </Grid>

            <Border
                Padding="10"
                BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="{Binding JobsDetailPasswordLibrary}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource PlcAccentBrush}"
                        Text="{Binding JobsPasswordDropFeedbackText}"
                        Visibility="{Binding JobsPasswordDropFeedbackText, Converter={StaticResource StringToVis}}" />
                    <Border
                        x:Name="PasswordDropPanel"
                        MinHeight="36"
                        AllowDrop="True"
                        Background="{ThemeResource PlcLayerFillBrush}"
                        BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        DragOver="PasswordDropPanel_DragOver"
                        DragLeave="PasswordDropPanel_DragLeave"
                        Drop="PasswordDropPanel_Drop">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                            Text="{Binding JobsDetailPasswordDropHint}" />
                    </Border>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding OpenPasswordSamplesCommand}" Content="{Binding JobsDetailBrowsePasswordLibrary}" />
                        <Button Grid.Column="1" Command="{Binding SyncPasswordManifestCommand}" Content="{Binding JobsDetailScanUpdate}" />
                        <Button Grid.Column="2" Command="{Binding MatchPasswordCommand}" Content="{Binding JobsDetailMatchPassword}" />
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Text="{Binding PasswordEntryCountText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcAccentBrush}"
                Text="{Binding JobsInboxDropFeedbackText}"
                Visibility="{Binding JobsInboxDropFeedbackText, Converter={StaticResource StringToVis}}" />
            <Border
                x:Name="InboxDropPanel"
                MinHeight="40"
                AllowDrop="True"
                Background="{ThemeResource PlcLayerFillBrush}"
                BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                DragOver="InboxDropPanel_DragOver"
                DragLeave="InboxDropPanel_DragLeave"
                Drop="InboxDropPanel_Drop">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding JobsDetailInboxDropHint}" />
            </Border>

            <StackPanel
                Orientation="Horizontal"
                Spacing="12"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <CheckBox Content="7z-zstd" IsChecked="{Binding Enable7z, Mode=TwoWay}" />
                <CheckBox Content="tar.zst" IsChecked="{Binding EnableTarZst, Mode=TwoWay}" />
            </StackPanel>

            <Grid
                ColumnSpacing="8"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Command="{Binding OpenThreadCommand}" Content="{Binding JobsDetailOpenThread}" />
                <Button Grid.Column="1" Command="{Binding OpenInboxCommand}" Content="{Binding JobsDetailOpenInbox}" />
                <Button Grid.Column="2" Command="{Binding ScanInboxCommand}" Content="{Binding JobsDetailScanInbox}" />
                <Button Grid.Column="3" Command="{Binding DownloadThreadAttachmentsCommand}" Content="{Binding JobsDetailDownloadThreadAttachments}" />
                <Button Grid.Column="4" Command="{Binding ExtractCommand}" Content="{Binding JobsDetailExtract}" />
                <Button
                    Grid.Column="5"
                    Command="{Binding ProcessCommand}"
                    Content="{Binding JobsDetailProcess}"
                    FontWeight="SemiBold" />
                <Button
                    Grid.Column="6"
                    Command="{Binding RunFullPipelineCommand}"
                    Content="{Binding JobsDetailRunFullPipeline}"
                    FontWeight="SemiBold" />
                <Button
                    Grid.Column="7"
                    Command="{Binding RetryJobCommand}"
                    Content="{Binding JobsDetailRetryJob}"
                    Visibility="{Binding IsSelectedJobFailed, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource PlcAccentBrush}"
                Text="{Binding PipelineProgressText}"
                TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding OpenExtractCommand}" Content="{Binding JobsDetailOpenExtract}" />
                <Button Command="{Binding OpenOutputCommand}" Content="{Binding JobsDetailOpenOutput}" />
            </StackPanel>

            <Expander
                Header="{Binding JobsDetailAdvancedActions}"
                IsExpanded="False"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="8">
                    <Button
                        HorizontalAlignment="Left"
                        Command="{Binding ExportNightlyAutomationScriptCommand}"
                        Content="{Binding JobsDetailExportNightlyScript}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            Header="{Binding JobsDetailMergeSourceJob}"
                            ItemsSource="{Binding MergeSourceJobOptions}"
                            PlaceholderText="{Binding JobsDetailSelectSourceJob}"
                            SelectedItem="{Binding SelectedMergeSourceJob, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Command="{Binding MergeIntoSelectedJobCommand}"
                            Content="{Binding JobsDetailMergeIntoCurrent}" />
                    </Grid>
                </StackPanel>
            </Expander>
            </StackPanel>

            <Border x:Name="WizardSectionBorder" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="10">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding JobsWizardTitle}" />
                    <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardSummaryText}" TextWrapping="Wrap" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding JobsWizardHint}"
                        TextWrapping="Wrap"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                    <Border
                        Padding="8,6"
                        Background="{ThemeResource PlcAccentSubtleBrush}"
                        BorderBrush="{ThemeResource PlcAccentBrush}"
                        BorderThickness="2"
                        CornerRadius="6"
                        Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource PlcHintText}"
                                Text="{Binding JobsSimpleHint}"
                                TextWrapping="Wrap" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding WizardStepHintText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ProgressBar
                        x:Name="WizardStepProgressBar"
                        Maximum="100"
                        Value="{Binding WizardStepProgress, Mode=OneWay}"
                        Visibility="{Binding ShowWizardStepsContent, Converter={StaticResource BoolToVis}}" />

                    <StackPanel
                        Spacing="4"
                        Visibility="{Binding IsRefreshingJobs, Converter={StaticResource BoolToVis}}">
                        <ProgressRing Width="16" Height="16" IsActive="True" />
                        <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding JobsWizardStepsLoadingHint}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding ShowWizardStepsContent, Converter={StaticResource BoolToVis}}">
                        <ItemsControl
                            x:Name="WizardStepsItemsControl"
                            ItemsSource="{Binding WizardSteps}"
                            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:JobWizardStepItem">
                                    <Button
                                        MinWidth="96"
                                        Padding="8,6"
                                        Background="{ThemeResource PlcLayerFillBrush}"
                                        BorderBrush="{x:Bind IsCurrent, Converter={StaticResource WizardCurrentBorderConverter}}"
                                        BorderThickness="{x:Bind IsCurrent, Converter={StaticResource WizardBorderThicknessConverter}}"
                                        Command="{Binding DataContext.SelectWizardStepCommand, ElementName=JobsPageRoot}"
                                        CommandParameter="{x:Bind TabIndex}">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{ThemeResource PlcAccentBrush}"
                                                Text="{x:Bind Title}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                                Text="{x:Bind StatusText}"
                                                TextAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="{Binding ShowWizardStepList, Converter={StaticResource BoolToVis}}">
                        <StackPanel Spacing="8">
                            <ListView
                                x:Name="WizardStepsListView"
                                IsItemClickEnabled="True"
                                ItemClick="WizardStepsListView_ItemClick"
                                ItemsSource="{Binding WizardSteps}"
                                SelectionMode="None"
                                Visibility="{Binding HasWizardJob, Converter={StaticResource BoolToVis}}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:JobWizardStepItem">
                                        <Border
                                            Padding="10"
                                            Background="{ThemeResource PlcLayerFillBrush}"
                                            BorderBrush="{x:Bind IsCurrent, Converter={StaticResource WizardCurrentBorderConverter}}"
                                            BorderThickness="{x:Bind IsCurrent, Converter={StaticResource WizardBorderThicknessConverter}}"
                                            CornerRadius="6">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Foreground="{ThemeResource PlcAccentBrush}"
                                                    Text="{x:Bind Order}" />
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                                        Text="{x:Bind Description}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind StatusText}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{Binding ShowWizardStepsContent, Converter={StaticResource BoolToVis}}">
                        <Button
                            Style="{StaticResource PlcPrimaryButton}"
                            Command="{Binding ExecuteWizardStepCommand}"
                            Content="{Binding ExecuteWizardStepLabel}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}" />
                        <Button
                            Command="{Binding WizardPrevStepCommand}"
                            Content="{Binding WizardPrevLabel}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}" />
                        <Button
                            Command="{Binding WizardNextStepCommand}"
                            Content="{Binding WizardNextLabel}"
                            IsEnabled="{Binding IsRefreshingJobs, Converter={StaticResource InverseBool}}" />
                    </StackPanel>

                    <TabView
                        x:Name="WizardTabView"
                        SelectionChanged="WizardTabView_SelectionChanged"
                        Visibility="{Binding ShowWizardStepsContent, Converter={StaticResource BoolToVis}}">
                        <TabViewItem Header="{Binding WizardTabHeaderPrepare, Mode=OneWay}">
                            <StackPanel x:Name="WizardStepPreparePanel" Spacing="8" Padding="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding WizardStepPrepareHint}"
                                    TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedJob.StatusLabel, FallbackValue=—}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding RunFullPipelineCommand}" Content="{Binding JobsDetailRunFullPipeline}" FontWeight="SemiBold" />
                                    <Button Command="{Binding OpenExtractCommand}" Content="{Binding JobsDetailOpenExtract}" />
                                    <Button Command="{Binding OpenOutputCommand}" Content="{Binding JobsDetailOpenOutput}" />
                                </StackPanel>
                            </StackPanel>
                        </TabViewItem>
                        <TabViewItem Header="{Binding WizardTabHeaderLinks, Mode=OneWay}">
                            <StackPanel x:Name="WizardStepLinksPanel" Spacing="8" Padding="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding PublishStatusText}"
                                    TextWrapping="Wrap" />
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Header="{Binding JobsDetailBaiduLink}"
                                        Text="{Binding BaiduLink, Mode=TwoWay}" />
                                    <TextBox
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Header="{Binding JobsDetailExtractCode}"
                                        Text="{Binding BaiduPassword, Mode=TwoWay}" />
                                    <Button
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding OpenBaiduLinkCommand}"
                                        Content="{Binding JobsDetailOpenBaidu}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Header="{Binding JobsDetailQuarkLink}"
                                        Text="{Binding QuarkLink, Mode=TwoWay}" />
                                    <TextBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Header="{Binding JobsDetailExtractCode}"
                                        Text="{Binding QuarkPassword, Mode=TwoWay}" />
                                    <Button
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding OpenQuarkLinkCommand}"
                                        Content="{Binding JobsDetailOpenQuark}" />
                                    <TextBox
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Header="{Binding JobsDetailTelegramPostLink}"
                                        PlaceholderText="https://t.me/..."
                                        Text="{Binding TelegramPostLink, Mode=TwoWay}" />
                                </Grid>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Header="{Binding JobsDetailTelegramChannel}"
                                        PlaceholderText="https://t.me/your_channel"
                                        Text="{Binding TelegramChannelUrl, Mode=TwoWay}" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SaveTelegramChannelCommand}"
                                        Content="{Binding JobsDetailSaveChannel}" />
                                </Grid>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Header="{Binding JobsDetailTags}"
                                        PlaceholderText="{Binding JobsDetailTagsPlaceholder}"
                                        Text="{Binding JobTagsText, Mode=TwoWay}" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SaveJobTagsCommand}"
                                        Content="{Binding JobsDetailSaveTags}" />
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding BatchAppendTagsCommand}"
                                        Content="{Binding JobsDetailBatchAppend}" />
                                    <Button
                                        Grid.Column="3"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding TogglePinJobCommand}"
                                        Content="{Binding TogglePinJobButtonText}" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding SavePublishLinksCommand}" Content="{Binding JobsDetailSaveLinks}" FontWeight="SemiBold" />
                                    <Button Command="{Binding ParseClipboardLinksCommand}" Content="{Binding JobsDetailParseClipboardLinks}" />
                                    <Button Command="{Binding CopyAllPublishLinksCommand}" Content="{Binding JobsDetailCopyAllLinks}" />
                                    <Button Command="{Binding OpenAllPublishLinksCommand}" Content="{Binding JobsDetailOpenAllLinks}" />
                                </StackPanel>
                            </StackPanel>
                        </TabViewItem>
                        <TabViewItem Header="{Binding WizardTabHeaderCopy, Mode=OneWay}">
                            <StackPanel x:Name="WizardStepCopyPanel" Spacing="8" Padding="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding WizardStepCopyHint}"
                                    TextWrapping="Wrap" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox
                                        Header="{Binding JobsDetailBlurbTemplate}"
                                        ItemsSource="{Binding PublishTemplateNames}"
                                        SelectedItem="{Binding SelectedPublishTemplate, Mode=TwoWay}" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding GeneratePublishCopyCommand}"
                                        Content="{Binding JobsDetailGenerateCopy}"
                                        FontWeight="SemiBold" />
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding PreviewPublishTemplateCommand}"
                                        Content="{Binding JobsDetailPreviewTemplate}" />
                                    <Button
                                        Grid.Column="3"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding CopyPublishCopyCommand}"
                                        Content="{Binding JobsDetailCopyTgCopy}" />
                                    <Button
                                        Grid.Column="4"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding OpenPublishTemplatesCommand}"
                                        Content="{Binding JobsDetailEditPublishTemplates}" />
                                </Grid>
                                <TextBox
                                    AcceptsReturn="True"
                                    FontFamily="Consolas"
                                    Header="{Binding JobsDetailPublishCopyPreview}"
                                    Height="160"
                                    IsReadOnly="True"
                                    Text="{Binding PublishCopyText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </TabViewItem>
                        <TabViewItem Header="{Binding WizardTabHeaderPublish, Mode=OneWay}">
                            <StackPanel x:Name="WizardStepPublishPanel" Spacing="8" Padding="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding PublishStatusText}"
                                    TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        Command="{Binding MarkAllChannelsPublishedCommand}"
                                        Content="{Binding JobsDetailMarkAllPublished}"
                                        FontWeight="SemiBold" />
                                    <Button Command="{Binding MarkBaiduPublishedCommand}" Content="{Binding JobsDetailMarkBaiduPublished}" />
                                    <Button Command="{Binding MarkQuarkPublishedCommand}" Content="{Binding JobsDetailMarkQuarkPublished}" />
                                    <Button Command="{Binding MarkTelegramPublishedCommand}" Content="{Binding JobsDetailMarkTelegramPublished}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding OpenTelegramChannelCommand}" Content="{Binding JobsDetailOpenTgChannel}" />
                                    <Button Command="{Binding CopyAndOpenTelegramCommand}" Content="{Binding JobsDetailCopyAndOpenTg}" />
                                    <Button Command="{Binding SendToTelegramBotCommand}" Content="{Binding JobsDetailBotSendToTg}" />
                                    <Button Command="{Binding OpenPublishedFolderCommand}" Content="{Binding JobsDetailOpenPublishedFolder}" />
                                </StackPanel>
                            </StackPanel>
                        </TabViewItem>
                    </TabView>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding JobsLogTitle}" />
                <Button
                    Grid.Column="1"
                    Command="{Binding CopyJobLogCommand}"
                    Content="{Binding JobsDetailCopyLog}" />
                <Button
                    Grid.Column="2"
                    Command="{Binding ExportJobLogCommand}"
                    Content="{Binding JobsDetailExportLog}"
                    Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            </Grid>
            <TextBox
                x:Name="JobLogBox"
                AcceptsReturn="True"
                FontFamily="Consolas"
                Height="220"
                IsReadOnly="True"
                Text="{Binding JobLogText}"
                TextWrapping="Wrap" />
        </StackPanel>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>