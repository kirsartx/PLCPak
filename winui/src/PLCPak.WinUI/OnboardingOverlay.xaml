<UserControl
    x:Class="PLCPak.WinUI.OnboardingOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid Background="#99000000">
        <Border
            x:Name="CardBorder"
            MaxWidth="480"
            Margin="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource PlcContentCard}">
            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="StepTitleText"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource PlcTitleBarTextBrush}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="StepBodyText"
                    FontSize="14"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    TextWrapping="Wrap" />
                <ProgressBar
                    x:Name="StepProgress"
                    Foreground="{ThemeResource PlcAccentBrush}"
                    Maximum="4"
                    Minimum="0"
                    Value="1" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="EscHintTextBlock"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="SkipBtn"
                        Grid.Column="1"
                        MinWidth="88"
                        MinHeight="32"
                        Click="SkipBtn_Click" />
                    <Button
                        x:Name="NextBtn"
                        Grid.Column="2"
                        MinWidth="120"
                        MinHeight="32"
                        Click="NextBtn_Click"
                        Style="{StaticResource PlcPrimaryButton}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>