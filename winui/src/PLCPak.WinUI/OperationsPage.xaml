<UserControl
    x:Class="PLCPak.WinUI.OperationsPage"
    x:Name="OperationsPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:infra="using:PLCPak.WinUI.Infrastructure">

    <UserControl.Resources>
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
        <infra:BoolToVisibilityConverter x:Key="BoolToVis" />
        <infra:IntToVisibilityConverter x:Key="IntToVis" />
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <StackPanel
            Spacing="4"
            Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding OpsRefreshingHint}" />
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PlcPageTitle}" Text="{Binding OpsTitle}" />
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding OpsSimpleHint}"
                    Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}" />
                <TextBlock
                    FontSize="11"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding OpsProHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WorkspacePath}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Top"
                Command="{Binding RefreshCommand}"
                Content="{Binding OpsRefreshLabel}" />
        </Grid>

        <Border
            Padding="12"
            Background="{ThemeResource PlcAccentSubtleBrush}"
            BorderBrush="{ThemeResource PlcAccentBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="4">
                <TextBlock FontWeight="SemiBold" Text="{Binding OpsTaskOverviewTitle}" />
                <TextBlock
                    FontSize="14"
                    Text="{Binding QuickStatsLine}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border
            Style="{StaticResource PlcContentCard}"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding OpsSectionsTitle}" />
                <ItemsControl ItemsSource="{Binding OperationsSections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,6"
                                Padding="8,6"
                                Background="{ThemeResource PlcLayerFillBrush}"
                                BorderBrush="{ThemeResource PlcCardStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                        Text="{Binding SummaryText}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Expander Header="{Binding OpsFullSummaryHeader}" IsExpanded="False">
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding OperationsSummaryText}"
                        TextWrapping="Wrap" />
                </Expander>
            </StackPanel>
        </Border>

        <Grid
            ColumnSpacing="12"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding OpsMaintenanceCheckTitle}" />
                    <TextBlock Text="{Binding MaintenanceSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource PlcContentCard}">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding OpsJobHealthTitle}" />
                    <TextBlock Text="{Binding HealthSummaryText}" TextWrapping="Wrap" />
                    <TextBlock
                        Style="{StaticResource PlcHintText}"
                        Text="{Binding WorkflowSummaryText}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Padding="12"
            BorderBrush="{ThemeResource PlcCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="{Binding OpsStaleJobsTitle}" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding StaleJobsCountText}" />
                </Grid>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding OpsStaleJobsHint}"
                    TextWrapping="Wrap" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding StaleJobsEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding StaleJobsEmptyHint, Converter={StaticResource StringToVis}}" />
                <StackPanel
                    Spacing="4"
                    Visibility="{Binding IsRefreshing, Converter={StaticResource BoolToVis}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding StaleJobsLoadingHint}" />
                </StackPanel>
                <ListView
                    Visibility="{Binding ShowStaleJobsList, Converter={StaticResource BoolToVis}}"
                    MaxHeight="280"
                    IsItemClickEnabled="True"
                    ItemClick="StaleJobs_ItemClick"
                    ItemsSource="{Binding StaleJobs}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Reason}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding DaysNotUpdatedText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border
            Style="{StaticResource PlcContentCard}"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding OpsDuplicateScanTitle}" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding DuplicateGroupsCountText}" />
                </Grid>
                <TextBlock Text="{Binding DuplicateScanSummary}" TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding DuplicateMergeSuggestionSummary}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding DuplicateMergeSuggestionsCountText}" />
                </Grid>
                <ListView
                    MaxHeight="160"
                    IsItemClickEnabled="True"
                    ItemClick="DuplicateMergeSuggestions_ItemClick"
                    ItemsSource="{Binding DuplicateMergeSuggestions}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Reason}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding BatchMergeDuplicatesCommand}" Content="{Binding OpsAutoMergeDuplicatesLabel}" />
                    <Button Command="{Binding PreviewBatchMergeDuplicatesCommand}" Content="{Binding OpsPreviewMergeLabel}" />
                    <Button Command="{Binding ExportBatchMergePreviewCommand}" Content="{Binding OpsExportMergePreviewJsonLabel}" />
                    <Button Command="{Binding ExportDuplicateReportCommand}" Content="{Binding OpsExportDuplicateReportLabel}" />
                    <Button Command="{Binding ExportDuplicateMergeSuggestionsCommand}" Content="{Binding OpsExportMergeSuggestionsLabel}" />
                </StackPanel>
                <ListView
                    MaxHeight="200"
                    IsItemClickEnabled="True"
                    ItemClick="BatchMergePreviewItems_ItemClick"
                    ItemsSource="{Binding BatchMergePreviewItems}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Reason}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding MergePreviewEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding MergePreviewEmptyHint, Converter={StaticResource StringToVis}}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding DuplicateGroupsEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding DuplicateGroupsEmptyHint, Converter={StaticResource StringToVis}}" />
                <ListView
                    MaxHeight="220"
                    IsItemClickEnabled="True"
                    ItemClick="DuplicateGroups_ItemClick"
                    ItemsSource="{Binding DuplicateGroups}"
                    SelectionMode="None"
                    Visibility="{Binding DuplicateGroupCount, Converter={StaticResource IntToVis}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Reason}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Expander
            Header="{Binding OpsActivityLogAndStatsHeader}"
            IsExpanded="True"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
        <Border
            Padding="12"
            Background="{ThemeResource PlcCardBackgroundBrush}"
            BorderBrush="{ThemeResource PlcCardStrokeBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="{Binding OpsActivityLogTitle}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding OpsActivityLogHint}"
                    TextWrapping="Wrap" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogPageSummary}"
                    TextWrapping="Wrap" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding OpsRecentActiveCategoriesLabel}" />
                <ItemsControl ItemsSource="{Binding RecentCategories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Padding="10,4"
                                Command="{Binding DataContext.SelectRecentCategoryCommand, ElementName=OperationsPageRoot}"
                                CommandParameter="{Binding}"
                                Content="{Binding}"
                                FontSize="12" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogFilterSummary}"
                    TextWrapping="Wrap"
                    Visibility="{Binding IsActivityLogFilterActive, Converter={StaticResource BoolToVis}}" />
                <Button
                    HorizontalAlignment="Left"
                    Command="{Binding ClearActivityLogFiltersCommand}"
                    Content="{Binding OpsClearFiltersLabel}"
                    Visibility="{Binding IsActivityLogFilterActive, Converter={StaticResource BoolToVis}}" />
                <TextBlock
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource PlcAccentBrush}"
                    Text="{Binding ActivityLogResultBadge}"
                    Visibility="{Binding ActivityLogResultBadge, Converter={StaticResource StringToVis}}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox
                        Width="180"
                        Header="{Binding OpsCategoryHeader}"
                        ItemsSource="{Binding ActivityCategories}"
                        SelectedItem="{Binding ActivityCategoryFilter, Mode=TwoWay}" />
                    <TextBox
                        Width="220"
                        Header="{Binding OpsKeywordHeader}"
                        PlaceholderText="{Binding OpsSearchActivityLogPlaceholder}"
                        Text="{Binding ActivityLogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Width="120"
                        Header="{Binding OpsDaysHeader}"
                        PlaceholderText="{Binding OpsDaysPlaceholder}"
                        Text="{Binding ActivityLogSinceDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{Binding IsActivityLogSearchPending, Converter={StaticResource BoolToVis}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{ThemeResource PlcSecondaryTextBrush}"
                        Text="{Binding ActivityLogSearchPendingHint}" />
                </StackPanel>
                <TextBlock
                    FontSize="11"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogSinceDaysHint}"
                    TextWrapping="Wrap" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding OpsBatchFilterShortcutLabel}" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button
                        Padding="10,4"
                        Command="{Binding FilterBatchActivityLogsCommand}"
                        Content="{Binding OpsFilterAllBatchLabel}"
                        FontSize="12" />
                    <Button
                        Padding="10,4"
                        Command="{Binding FilterBatchCategoryCommand}"
                        CommandParameter="archive"
                        Content="{Binding OpsFilterBatchArchiveLabel}"
                        FontSize="12" />
                    <Button
                        Padding="10,4"
                        Command="{Binding FilterBatchCategoryCommand}"
                        CommandParameter="delete"
                        Content="{Binding OpsFilterBatchDeleteLabel}"
                        FontSize="12" />
                    <Button
                        Padding="10,4"
                        Command="{Binding FilterBatchCategoryCommand}"
                        CommandParameter="tags"
                        Content="{Binding OpsFilterBatchTagsLabel}"
                        FontSize="12" />
                    <Button
                        Padding="10,4"
                        Command="{Binding FilterBatchCategoryCommand}"
                        CommandParameter="unarchive"
                        Content="{Binding OpsFilterBatchUnarchiveLabel}"
                        FontSize="12" />
                </StackPanel>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogBatchSummary}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ActivityLogBatchSummary, Converter={StaticResource StringToVis}}" />
                <ListView
                    MaxHeight="120"
                    IsItemClickEnabled="True"
                    ItemsSource="{Binding ActivityLogBatchStats}"
                    SelectionMode="None"
                    Visibility="{Binding ActivityLogBatchSummary, Converter={StaticResource StringToVis}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Button
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DataContext.FilterBatchCategoryFromStatCommand, ElementName=OperationsPageRoot}"
                                CommandParameter="{Binding}">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="48" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Text="{Binding Label}"
                                        TextTrimming="CharacterEllipsis" />
                                    <ProgressBar
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Maximum="100"
                                        Value="{Binding BarPercent}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{Binding Count}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    Visibility="{Binding ActivityLogBatchSummary, Converter={StaticResource StringToVis}}">
                    <Button
                        Command="{Binding ExportActivityLogBatchStatsAllCommand}"
                        Content="{Binding OpsExportBatchJsonCsvLabel}"
                        FontSize="12" />
                    <Button
                        Command="{Binding ExportActivityLogBatchStatsCommand}"
                        Content="{Binding OpsExportBatchJsonOnlyLabel}"
                        FontSize="12" />
                    <Button
                        Command="{Binding ExportActivityLogBatchStatsCsvCommand}"
                        Content="{Binding OpsExportBatchCsvOnlyLabel}"
                        FontSize="12" />
                </StackPanel>
                <TextBlock
                    FontSize="11"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogBatchShortcutHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ActivityLogBatchSummary, Converter={StaticResource StringToVis}}" />
                <TextBlock FontWeight="SemiBold" Text="{Binding OpsCategoryStatsTitle}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogStatsSummary}"
                    TextWrapping="Wrap" />
                <ListView
                    MaxHeight="180"
                    ItemsSource="{Binding ActivityLogStats}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{Binding Category}"
                                    TextTrimming="CharacterEllipsis" />
                                <ProgressBar
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="100"
                                    Value="{Binding BarPercent}" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{Binding Count}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogStatsEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ActivityLogStatsEmptyHint, Converter={StaticResource StringToVis}}" />
                <TextBlock FontWeight="SemiBold" Text="{Binding OpsLast7DaysActivityTitle}" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogDailyStatsSummary}"
                    TextWrapping="Wrap" />
                <ListView
                    MaxHeight="200"
                    ItemsSource="{Binding ActivityLogDailyStats}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{Binding Date}" />
                                <ProgressBar
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Maximum="100"
                                    Value="{Binding BarPercent}" />
                                <TextBlock
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="{Binding Count}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Command="{Binding ExportActivityLogStatsCommand}"
                        Content="{Binding OpsExportStatsJsonLabel}" />
                    <Button
                        Command="{Binding ExportActivityLogStatsCsvCommand}"
                        Content="{Binding OpsExportStatsCsvLabel}" />
                    <Button
                        Command="{Binding ExportActivityLogStatsHtmlCommand}"
                        Content="{Binding OpsExportStatsHtmlLabel}" />
                    <Button
                        Command="{Binding ExportActivityLogDailyStatsCsvCommand}"
                        Content="{Binding OpsExportDailyStatsCsvLabel}" />
                </StackPanel>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogLoadedSummary}"
                    Visibility="{Binding ActivityLogLoadedSummary, Converter={StaticResource StringToVis}}" />
                <ListView
                    MaxHeight="320"
                    ItemsSource="{Binding RecentActivity}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Category}" />
                                <TextBlock
                                    FontSize="12"
                                    Text="{Binding Message}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{Binding Timestamp}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                    Text="{Binding ActivityLogEmptyHint}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ActivityLogEmptyHint, Converter={StaticResource StringToVis}}" />
                <StackPanel
                    Spacing="6"
                    Visibility="{Binding ActivityLogHasMore, Converter={StaticResource BoolToVis}}">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{Binding IsLoadingMoreActivityLog, Converter={StaticResource BoolToVis}}">
                        <ProgressRing Width="16" Height="16" IsActive="True" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                            Text="{Binding ActivityLogLoadingMoreHint}" />
                    </StackPanel>
                    <Button
                        HorizontalAlignment="Left"
                        Command="{Binding LoadMoreActivityLogCommand}"
                        Content="{Binding OpsLoadMoreLabel}"
                        Visibility="{Binding IsLoadingMoreActivityLog, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                </StackPanel>
            </StackPanel>
        </Border>
        </Expander>

        <Expander Header="{Binding OpsCommonOpsHeader}" IsExpanded="True">
            <StackPanel Spacing="8">
                <Border
                    Padding="8,6"
                    Background="{ThemeResource PlcAccentSubtleBrush}"
                    BorderBrush="{ThemeResource PlcAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding HasBulkArchiveCandidates, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding BulkArchiveHint}" />
                </Border>
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding BulkArchiveHint}"
                    Visibility="{Binding HasBulkArchiveCandidates, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Style="{StaticResource PlcPrimaryButton}"
                        Command="{Binding BulkArchivePublishedCommand}"
                        Content="{Binding BulkArchiveButtonText}" />
                    <Button Command="{Binding ExportDailyReportCommand}" Content="{Binding OpsExportDailyLabel}" />
                    <Button
                        Command="{Binding ExportOperationsReportCommand}"
                        Content="{Binding OpsExportOpsReportLabel}"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                    <Button
                        Command="{Binding ExportNightlyAutomationScriptCommand}"
                        Content="{Binding OpsExportNightlyScriptLabel}"
                        Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </StackPanel>
        </Expander>

        <Expander
            Header="{Binding OpsBackupRestoreHeader}"
            IsExpanded="False"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding ExportAllJobsBackupCommand}" Content="{Binding OpsBackupAllJobsLabel}" />
                <Button Command="{Binding ExportFullBackupCommand}" Content="{Binding OpsBackupFullLabel}" />
                <Button Command="{Binding ImportFullBackupCommand}" Content="{Binding OpsRestoreFullBackupLabel}" />
            </StackPanel>
        </Expander>

        <Expander
            Header="{Binding OpsActivityLogMaintenanceHeader}"
            IsExpanded="False"
            Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding ExportActivityLogCommand}" Content="{Binding OpsExportActivityLogLabel}" />
                <Button Command="{Binding ExportActivityLogCsvCommand}" Content="{Binding OpsExportCsvLabel}" />
                <Button Command="{Binding TrimActivityLogCommand}" Content="{Binding OpsTrimActivityLogLabel}" />
                <Button Command="{Binding ArchiveActivityLogCommand}" Content="{Binding OpsArchiveActivityLogLabel}" />
                <Button Command="{Binding ExportMachineProfileCommand}" Content="{Binding OpsExportMachineProfileLabel}" />
                <Button Command="{Binding ImportMachineProfileCommand}" Content="{Binding OpsImportMachineProfileLabel}" />
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>