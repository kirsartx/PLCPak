<ContentDialog
    x:Class="PLCPak.WinUI.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="PLCPak 设置"
    PrimaryButtonText="保存"
    CloseButtonText="取消"
    DefaultButton="Primary">

    <StackPanel Spacing="12" MinWidth="420">
        <ScrollViewer MaxHeight="520">
            <StackPanel Spacing="8">
                <Expander x:Name="AppearanceExpander" IsExpanded="True">
                    <StackPanel Spacing="12">
                        <ComboBox x:Name="AppThemeBox" Header="界面主题">
                            <ComboBoxItem Content="亮色" Tag="light" />
                            <ComboBoxItem Content="暗色" Tag="dark" />
                        </ComboBox>
                        <ComboBox x:Name="UiLanguageBox" Header="界面语言">
                            <ComboBoxItem Content="简体中文" Tag="zh" />
                            <ComboBoxItem Content="English" Tag="en" />
                        </ComboBox>
                        <CheckBox
                            x:Name="ProfessionalModeCheck"
                            Content="专业模式（显示全部高级功能，默认关闭为简易傻瓜式）" />
                        <CheckBox
                            x:Name="WizardCompletionFeedbackCheck"
                            Content="向导步骤完成时播放声音与触觉反馈"
                            IsChecked="True" />
                        <CheckBox x:Name="ReduceMotionCheck" Content="减少动画（跳过页面切换与向导动效）" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="WorkspaceExpander" IsExpanded="True">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="ConfigPathText"
                            FontSize="12"
                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ExportConfigBtn" Click="ExportConfigBtn_Click" Content="导出配置" />
                            <Button x:Name="ImportConfigBtn" Click="ImportConfigBtn_Click" Content="导入配置" />
                        </StackPanel>
                        <TextBox x:Name="WorkspaceRootBox" Header="工作区根目录" PlaceholderText="留空使用默认 jobs 目录" />
                        <TextBox
                            x:Name="ExtractPasswordsBox"
                            Header="解压密码候选（每行一条）"
                            AcceptsReturn="True"
                            Height="100"
                            TextWrapping="Wrap" />
                        <TextBox x:Name="DefaultPublishTemplateIdBox" Header="默认发布模板 ID" PlaceholderText="telegram-default" />
                        <TextBox Header="分卷大小(MB)" x:Name="VolumeSizeBox" />
                        <TextBox Header="扫描超时(秒)" x:Name="ScanTimeoutBox" />
                        <TextBox Header="确认阈值" x:Name="ConfirmThresholdBox" />
                        <TextBox Header="压缩线程(0自动)" x:Name="CompressThreadsBox" />
                        <TextBox Header="临时目录" x:Name="TempDirBox" PlaceholderText="留空使用系统临时目录" />
                        <TextBox Header="清单过期(天)" x:Name="ManifestStaleBox" />
                        <CheckBox x:Name="RecycleBinCheck" Content="删除到回收站" />
                        <CheckBox x:Name="SkipStoreCheck" Content="已压缩文件存储模式(-ms=on)" />
                        <CheckBox x:Name="PreviewBeforeCleanCheck" Content="一键执行前预览确认" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="JobsExpander" IsExpanded="True">
                    <StackPanel Spacing="12">
                        <TextBox
                            x:Name="DefaultJobTagsBox"
                            Header="新建任务默认标签（每行一条）"
                            AcceptsReturn="True"
                            Height="80"
                            PlaceholderText="例如: 优先&#x0a;待补链"
                            TextWrapping="Wrap" />
                        <CheckBox x:Name="ShowWelcomeOnStartupCheck" Content="启动时显示欢迎引导" />
                        <Button
                            x:Name="ReplayOnboardingBtn"
                            HorizontalAlignment="Left"
                            Click="ReplayOnboardingBtn_Click"
                            Content="重新播放新手引导" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="ShortcutsExpander">
                    <StackPanel Spacing="12">
                        <CheckBox x:Name="DisableGlobalShortcutsCheck" Content="禁用全局快捷键" />
                        <TextBlock x:Name="ShortcutsDisableSectionTitle" Text="单独禁用快捷键（不影响命令面板菜单）" FontWeight="SemiBold" />
                        <CheckBox x:Name="DisableShortcutBatchArchiveFiltered" Content="Ctrl+Shift+A 批量归档筛选" />
                        <CheckBox x:Name="DisableShortcutBatchArchiveSelected" Content="Ctrl+Shift+G 多选批量归档" />
                        <CheckBox x:Name="DisableShortcutBatchUnarchiveSelected" Content="Ctrl+Shift+U 多选批量恢复" />
                        <CheckBox x:Name="DisableShortcutBatchDeleteSelected" Content="Ctrl+Shift+D 多选批量删除" />
                        <CheckBox x:Name="DisableShortcutBatchTags" Content="Ctrl+Shift+T 多选批量标签" />
                        <CheckBox x:Name="DisableShortcutExportStatsHtml" Content="Ctrl+Shift+H 导出统计 HTML" />
                        <CheckBox x:Name="DisableShortcutFilterBatchActivity" Content="Ctrl+Shift+B 筛选批量操作日志" />
                        <CheckBox x:Name="DisableShortcutExportBatchStatsJson" Content="Ctrl+Shift+J 导出批量统计 JSON" />
                        <CheckBox x:Name="DisableShortcutExportBatchStatsCsv" Content="Ctrl+Shift+? 导出批量统计 CSV" />
                        <CheckBox x:Name="DisableShortcutExportBatchStatsAll" Content="Ctrl+Shift+O 导出批量统计 JSON+CSV" />
                        <ComboBox x:Name="HtmlReportThemeBox" Header="活动日志 HTML 报告默认主题">
                            <ComboBoxItem Content="亮色" Tag="light" />
                            <ComboBoxItem Content="暗色" Tag="dark" />
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="EditShortcutOverridesBtn"
                                Click="EditShortcutOverridesBtn_Click"
                                Content="自定义快捷键映射" />
                            <Button
                                x:Name="ExportShortcutProfileBtn"
                                Click="ExportShortcutProfileBtn_Click"
                                Content="导出快捷键" />
                            <Button
                                x:Name="ImportShortcutProfileBtn"
                                Click="ImportShortcutProfileBtn_Click"
                                Content="导入快捷键" />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <Expander x:Name="IntegrationsExpander">
                    <StackPanel Spacing="12">
                        <TextBox x:Name="TelegramChannelUrlBox" Header="Telegram 频道链接" PlaceholderText="https://t.me/your_channel" />
                        <PasswordBox x:Name="TelegramBotTokenBox" Header="Telegram Bot Token" />
                        <CheckBox x:Name="AutoDownloadThreadAttachmentsCheck" Content="从帖子创建时自动下载附件" />
                        <TextBox x:Name="ForumDownloadMaxSizeBox" Header="论坛附件下载上限(MB)" />
                        <CheckBox x:Name="AutoArchiveAfterPublishCheck" Content="发布后自动归档" />
                        <CheckBox x:Name="AutoGenerateCopyAfterProcessCheck" Content="处理后自动生成文案" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="NightlyExpander">
                    <StackPanel Spacing="12">
                        <CheckBox x:Name="NightlyAutoSendTgCheck" Content="夜间全流程脚本自动批量发送 TG" />
                        <CheckBox x:Name="NightlyAutoScanDuplicatesCheck" Content="夜间全流程脚本自动扫描重复任务" />
                        <CheckBox x:Name="NightlyAutoMergeDuplicatesCheck" Content="夜间全流程脚本自动合并重复任务" />
                        <CheckBox x:Name="NightlyAutoTrimActivityLogCheck" Content="夜间全流程脚本自动清理活动日志" />
                        <CheckBox x:Name="NightlyExportActivityLogStatsBothCheck" Content="夜间全流程脚本同时导出活动日志统计 CSV 与 HTML" />
                        <CheckBox x:Name="NightlyExportActivityLogStatsCheck" Content="夜间全流程脚本自动导出活动日志统计 CSV" />
                        <CheckBox x:Name="NightlyExportActivityLogStatsHtmlCheck" Content="夜间全流程脚本自动导出活动日志统计 HTML" />
                        <CheckBox x:Name="NightlyExportActivityLogBatchStatsAllCheck" Content="夜间全流程脚本自动导出批量操作统计 JSON+CSV" />
                        <CheckBox x:Name="NightlyExportPinnedJobsCsvCheck" Content="夜间全流程脚本自动导出置顶任务 CSV" />
                        <TextBox
                            x:Name="ActivityLogKeepDaysBox"
                            Header="活动日志保留天数"
                            PlaceholderText="30" />
                        <TextBox
                            x:Name="ActivityLogPageSizeBox"
                            Header="活动日志每页条数"
                            PlaceholderText="20" />
                        <CheckBox x:Name="EnableScheduledBatchCheck" Content="启用定时批量（导出脚本供任务计划程序使用）" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ScheduledBatchHourBox"
                                Grid.Column="0"
                                Header="小时 (0-23)"
                                PlaceholderText="2" />
                            <TextBox
                                x:Name="ScheduledBatchMinuteBox"
                                Grid.Column="1"
                                Header="分钟 (0-59)"
                                PlaceholderText="0" />
                        </Grid>
                        <TextBox
                            x:Name="ScheduledBatchFilterBox"
                            Header="批量筛选 (active/failed/all)"
                            PlaceholderText="active" />
                    </StackPanel>
                </Expander>

                <Expander x:Name="AdvancedExpander">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="WhitelistSectionTitle" Text="白名单(每行一条)" />
                        <TextBox x:Name="WhitelistBox" AcceptsReturn="True" TextWrapping="Wrap" Height="100" />
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
        <Button
            x:Name="ShowShortcutsBtn"
            HorizontalAlignment="Left"
            Click="ShowShortcutsBtn_Click"
            Content="查看快捷键说明" />
    </StackPanel>
</ContentDialog>