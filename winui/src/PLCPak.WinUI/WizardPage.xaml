<UserControl
    x:Class="PLCPak.WinUI.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:infra="using:PLCPak.WinUI.Infrastructure"
    Loaded="WizardPage_Loaded">

    <UserControl.Resources>
        <infra:BoolToVisibilityConverter x:Key="BoolToVis" />
        <infra:InverseBoolConverter x:Key="InverseBool" />
        <infra:StringToVisibilityConverter x:Key="StringToVis" />
        <infra:WizardStepStatusConverter x:Key="WizardStatusConverter" />
        <infra:WizardStepCurrentBorderConverter x:Key="WizardCurrentBorderConverter" />
        <infra:WizardStepBorderThicknessConverter x:Key="WizardBorderThicknessConverter" />
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <StackPanel
            Spacing="4"
            Visibility="{Binding IsRefreshingWizard, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardRefreshingHint}" />
        </StackPanel>
        <TextBlock
            x:Name="WizardTitleBlock"
            Style="{StaticResource PlcPageTitle}"
            Text="{Binding WizardTitle}" />
        <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardSummary}" />

        <Border Style="{StaticResource PlcHeroCard}" Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="{Binding WizardSimpleHeroTitle}" />
                <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardSimpleFlowHint}" />
            </StackPanel>
        </Border>

        <Border
            Style="{StaticResource PlcContentCard}"
            Visibility="{Binding HasWorkflowSuggestions, Converter={StaticResource BoolToVis}}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding WizardOtherSuggestionsTitle}" />
                <ListView
                    IsItemClickEnabled="True"
                    ItemClick="WorkflowSuggestions_ItemClick"
                    ItemsSource="{Binding WorkflowSuggestions}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:WorkflowSuggestionItem"
                            xmlns:viewModels="using:PLCPak.WinUI.ViewModels">
                            <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayText}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                    Text="{x:Bind Reason}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                Header="{Binding WizardSelectJobHeader}"
                ItemsSource="{Binding WizardJobOptions}"
                PlaceholderText="{Binding WizardSelectJobPlaceholder}"
                SelectedItem="{Binding SelectedWizardJob, Mode=TwoWay}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Bottom"
                FontSize="12"
                Foreground="{ThemeResource PlcSecondaryTextBrush}"
                Text="{Binding WizardJobCountText}"
                Visibility="{Binding HasWizardJobs, Converter={StaticResource BoolToVis}}" />
        </Grid>
        <TextBlock
            Style="{StaticResource PlcHintText}"
            Text="{Binding WizardNoJobsHint}"
            Visibility="{Binding HasWizardJobs, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <Border Style="{StaticResource PlcContentCard}">
            <StackPanel Spacing="8">
                <TextBlock Style="{StaticResource PlcSectionTitle}" Text="{Binding WizardPublishStepsTitle}" />
                <StackPanel
                    Spacing="4"
                    Visibility="{Binding ShowWizardStepProgress, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Maximum="100" Value="{Binding WizardStepProgressPercent}" />
                    <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardStepProgressText}" />
                </StackPanel>
                <TextBlock
                    Style="{StaticResource PlcHintText}"
                    Text="{Binding WizardStepsEmptyHint}"
                    Visibility="{Binding WizardStepsEmptyHint, Converter={StaticResource StringToVis}}" />
                <StackPanel
                    Spacing="4"
                    Visibility="{Binding IsRefreshingWizard, Converter={StaticResource BoolToVis}}">
                    <ProgressRing Width="16" Height="16" IsActive="True" />
                    <TextBlock Style="{StaticResource PlcHintText}" Text="{Binding WizardStepsLoadingHint}" />
                </StackPanel>
                <ListView
                    x:Name="WizardStepsListView"
                    ItemsSource="{Binding Steps}"
                    SelectionMode="None"
                    Visibility="{Binding ShowWizardStepsList, Converter={StaticResource BoolToVis}}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="10"
                                Background="{ThemeResource PlcLayerFillBrush}"
                                BorderBrush="{Binding IsCurrent, Converter={StaticResource WizardCurrentBorderConverter}}"
                                BorderThickness="{Binding IsCurrent, Converter={StaticResource WizardBorderThicknessConverter}}"
                                CornerRadius="6">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource PlcAccentBrush}"
                                        Text="{Binding Order}" />
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{ThemeResource PlcSecondaryTextBrush}"
                                            Text="{Binding Description}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{Binding Status, Converter={StaticResource WizardStatusConverter}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button
                Style="{StaticResource PlcPrimaryButton}"
                Command="{Binding ExecuteCurrentStepCommand}"
                Content="{Binding ExecuteCurrentStepLabel}"
                IsEnabled="{Binding IsRefreshingWizard, Converter={StaticResource InverseBool}}" />
            <Button
                Command="{Binding RefreshWizardCommand}"
                Content="{Binding WizardRefreshLabel}"
                IsEnabled="{Binding IsRefreshingWizard, Converter={StaticResource InverseBool}}" />
            <Button
                Command="{Binding GoToJobCommand}"
                Content="{Binding WizardOpenJobLabel}"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
            <Button
                Command="{Binding RunAutomatableChainCommand}"
                Content="{Binding WizardAutoRunLabel}"
                IsEnabled="{Binding IsRefreshingWizard, Converter={StaticResource InverseBool}}"
                Visibility="{Binding IsProfessionalMode, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
    </StackPanel>
</UserControl>